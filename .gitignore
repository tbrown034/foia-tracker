# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# planning + agent operating docs (private until project is public-ready)
# Public-facing docs should live in README.md or a future /public-docs/ directory.
/docs/
/CLAUDE.md
/AGENTS.md
/.claude/
.env.local

# Cached upstream data dumps. The ingest scripts re-download as needed —
# nothing here belongs in git.
/data/raw/
/data/review/
